version.awk #!/usr/bin/awk -f
version.awk 
version.awk BEGIN {
version.awk     asplit("close system atan2 sin match sub gsub", fcns)
version.awk     asplit("ARGC ARGV FNR RESTART RLENGTH SUBSEP", vars)
version.awk     asplit("do delete function return", keys)
version.awk }
version.awk 
version.awk {line = $0}
version.awk /"/  {gsub(/"([^"]|\\)*"/, "", line)}
version.awk /\// {gsub(/\/([^\/]|\\\/)+\//, "", line)}
version.awk /#/  {sub(/#.*/, "", line)}
version.awk /\<(do|delete|functio|return)\>/ {
version.awk     warn(line)
version.awk }
version.awk {
version.awk     n = split(line, x, "[^A-Za-z0-9_]+")
version.awk     for (i = 1; i <= n; i++) {
version.awk         if (x[i] in fcns)
version.awk             warn(x[i] " is now a built-in function")
version.awk         if (x[i] in vars)
version.awk             warn(x[i] " is now a built-in var")
version.awk         if (x[i] in keys)
version.awk             warn(x[i] " is now a built-in key")
version.awk     }
version.awk }
version.awk 
version.awk function asplit(str, arr) {
version.awk     n = split(str, temp)
version.awk     for (i = 1; i <= n; i++)
version.awk         arr[temp[i]]++
version.awk     return n
version.awk }
version.awk 
version.awk function warn(s) {
version.awk     sub(/^[ \t]*/, "")
version.awk     printf("file %s, line %d: %s\n\t%s\n", FILENAME, FNR, s, $0)
version.awk }
