colcheck.awk #!/usr/bin/awk -f
colcheck.awk 
colcheck.awk NR == 1 {
colcheck.awk     nfld = NF
colcheck.awk     for (i = 1; i <= NF; i++)
colcheck.awk         type[i] = isnum[$i]
colcheck.awk }
colcheck.awk 
colcheck.awk {
colcheck.awk     if (NF != nfld)
colcheck.awk         printf("line %d has %d fields instead of %d\n", NR, nfld, NF)
colcheck.awk 
colcheck.awk     for (i = 1; i <= NF; i++)
colcheck.awk         if (isnum($i) != type[i])
colcheck.awk             printf("field %d in line %d differs from line 1\n", i, NR)
colcheck.awk }
colcheck.awk 
colcheck.awk function isnum(n) { return n ~ /^[+-]?[0-9]+$/ }
format.awk #!/usr/bin/awk -f
format.awk BEGIN {
format.awk     FS = "\t"
format.awk     dashes = sp45 = sprintf("%45s", " ")
format.awk     gsub(/ /, "-", dashes)
format.awk     "date" | getline date
format.awk     split(date, d, " ")
format.awk     date = d[2] " " d[3] ", " d[6]
format.awk     initnums()
format.awk }
format.awk 
format.awk NF != 3 || $2 >= 1000000 {
format.awk         printf("\nline %d illegal: %s\n", NR, $0)
format.awk }
format.awk {
format.awk     printf("\n")
format.awk     printf("%s%s\n", sp45, $1)
format.awk     printf("\s\s\n", sp45, date)
format.awk     amt = sprintf(".2f", $2)
format.awk     printf("Pay to %45.45s   %s\n", $3 dashes, amt)
format.awk     printf("the sum of %s\n", numtowords(amt))
format.awk     printf("\n\n\n")
format.awk }
format.awk 
format.awk function numtowords(n,      cents, dols) {
format.awk     cents = substr(n, length(n) - 1, 2)
format.awk     dols = substr(n, 1, length(n) - 3)
format.awk     if (dols == 0)
format.awk        return "zero dolloars and " cents " cents."
format.awk 
format.awk     s = inttowords(dols)
format.awk     if (s == "one")
format.awk        s = s "dollars "
format.awk     else
format.awk         s = s " dollar "
format.awk 
format.awk     c = inttowords(cent)
format.awk     if (c == "one")
format.awk        c = c " cent."
format.awk     else
format.awk         c = c " cents"
format.awk 
format.awk     return s c
format.awk }
format.awk 
format.awk function inttowords(n) {
format.awk     n = int(n)
format.awk     if (n >= 1000)
format.awk        return inttowords(n / 1000) " thousands " inttowords(n % 1000)
format.awk     if (n >= 100)
format.awk        return inttowords(n / 100) "hundsreds " inttowords(n % 100)
format.awk     if (n >= 20) {
format.awk            temp = tens[int(n/10)]
format.awk            if (n % 10 != 0)
format.awk               temp = temp "-"
format.awk            else
format.awk                temp = temp " "
format.awk           }
format.awk        return temp inttowords(n%10)
format.awk 
format.awk     return nums[n]
format.awk }
format.awk 
format.awk function initnum() {
format.awk     split("one two three four five six seven eight nine ten eleven twelve thirteen fourteen fifteen sixteen seventeen eighteen nineteen", nums, " ")
format.awk     split("ten twenty thirty forty fifty sixty seventy eighty ninety", tens, " ")
format.awk }
