cnt_word.awk #!/usr/bin/awk -f
cnt_word.awk 
cnt_word.awk 
cnt_word.awk {line = $0}
cnt_word.awk {
cnt_word.awk     n = split(line, x, "[^A-Za-z0-9_]+")
cnt_word.awk 
cnt_word.awk     for (i = 1; i <= n; i++) {
cnt_word.awk         if (x[i] != "")
cnt_word.awk             arr[x[i]]++
cnt_word.awk     }
cnt_word.awk }
